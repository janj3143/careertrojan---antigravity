# Canonical host data mount for Docker runtime
# Keep this aligned with the dataset used by host-side scripts/pipelines.
CAREERTROJAN_HOST_DATA_ROOT=L:/Codec - Antigravity Data set

# --- Zendesk wiring keys added by setup_zendesk_env.ps1 ---
HELPDESK_BASE_URL=https://your-subdomain.zendesk.com
HELPDESK_PROVIDER=zendesk
ZENDESK_JWT_EMAIL_CLAIM=email
ZENDESK_SHARED_SECRET=__REPLACE_WITH_SECURE_SECRET__
HELPDESK_SSO_ENABLED=true
ZENDESK_JWT_EXTERNAL_ID_CLAIM=external_id
HELPDESK_MACROS_URL=https://your-subdomain.zendesk.com/agent/macros
HELPDESK_WIDGET_ENABLED=true
HELPDESK_QUEUE_URL=https://your-subdomain.zendesk.com/agent/queues
ZENDESK_JWT_NAME_CLAIM=name
ZENDESK_SUBDOMAIN=your-subdomain
HELPDESK_WIDGET_SCRIPT_URL=https://static.zdassets.com/ekr/snippet.js
