# Database
DATABASE_URL=postgresql://user:password@localhost:5432/careertrojan
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Auth0 / OAuth2 (optional, future external IdP integration)
AUTH_PROVIDER=local
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_ISSUER=https://your-tenant.auth0.com/
AUTH0_JWKS_URL=https://your-tenant.auth0.com/.well-known/jwks.json

# Google OAuth (optional, if enabling Google Sign-In)
GOOGLE_OAUTH_DOMAIN=https://www.careertrojan.com
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://www.careertrojan.com/api/auth/v1/google/callback
GOOGLE_OAUTH_AUTHORIZED_ORIGINS=https://www.careertrojan.com
GOOGLE_OAUTH_POST_LOGIN_URL=https://www.careertrojan.com/login

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=CareerTrojan

# Paths (J-drive runtime + L-drive data)
CAREERTROJAN_APP_ROOT=J:\Codec - runtime version\Antigravity\careertrojan
CAREERTROJAN_DATA_ROOT=L:\VS ai_data final - version
CAREERTROJAN_AI_DATA=L:\VS ai_data final - version\ai_data_final
CAREERTROJAN_PARSER_ROOT=L:\VS ai_data final - version\automated_parser
CAREERTROJAN_USER_DATA=L:\VS ai_data final - version\USER DATA
CAREERTROJAN_USER_DATA_MIRROR=E:\CareerTrojan\USER_DATA_COPY
CAREERTROJAN_APP_LOGS=J:\Codec - runtime version\Antigravity\careertrojan\logs

# Optional local tool binaries on J:
CAREERTROJAN_PYTHON_BIN=J:\Python311\python.exe
CAREERTROJAN_NODE_BIN=J:\nodej\node.exe
CAREERTROJAN_DOCKER_BIN=J:\docker-cli\docker.exe

# Feature Flags
ENABLE_AI_ENRICHMENT=True
ENABLE_MASQUERADE=True

# Helpdesk / Zendesk Wiring
HELPDESK_PROVIDER=stub
HELPDESK_WIDGET_ENABLED=true
HELPDESK_SSO_ENABLED=false
HELPDESK_BASE_URL=https://support.careertrojan.com
HELPDESK_QUEUE_URL=https://support.careertrojan.com/agent/queue
HELPDESK_MACROS_URL=https://support.careertrojan.com/agent/macros
HELPDESK_WIDGET_SCRIPT_URL=

# Zendesk Production Settings (required when HELPDESK_PROVIDER=zendesk)
ZENDESK_SUBDOMAIN=
ZENDESK_BASE_URL=
ZENDESK_SHARED_SECRET=
ZENDESK_WIDGET_SCRIPT_URL=https://static.zdassets.com/ekr/snippet.js
ZENDESK_JWT_EMAIL_CLAIM=email
ZENDESK_JWT_NAME_CLAIM=name
ZENDESK_JWT_EXTERNAL_ID_CLAIM=external_id
