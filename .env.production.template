# ===========================================================================
# Antigravity — CareerTrojan | Production Environment (.env.production)
# ===========================================================================
# Copy this to .env.production on the Hetzner server and fill in real values.
# This file is loaded by compose.production.yaml (env_file: .env.production)
#
# NEVER commit real credentials. Keep this template in git — the real
# .env.production lives only on the server at /home/careertrojan/careertrojan/
# ===========================================================================

# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=careertrojan
POSTGRES_PASSWORD=CHANGEME_GENERATE_RANDOM_32
POSTGRES_DB=careertrojan

# ── Application ────────────────────────────────────────────────────────────
SECRET_KEY=CHANGEME_GENERATE_RANDOM_64
ENVIRONMENT=production

# ── AI Keys (also in secrets/ files for /run/secrets) ──────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Data paths (Linux host directories) ───────────────────────────────────
# These directories are created by the deploy script.
CAREERTROJAN_DATA_ROOT=/opt/careertrojan/data/ai-data
CAREERTROJAN_USER_DATA=/opt/careertrojan/data/user-data
CAREERTROJAN_PARSER_DATA=/opt/careertrojan/data/parser

# ── Braintree (payments) ──────────────────────────────────────────────────
BRAINTREE_MERCHANT_ID=
BRAINTREE_PUBLIC_KEY=
BRAINTREE_PRIVATE_KEY=
BRAINTREE_ENVIRONMENT=sandbox
