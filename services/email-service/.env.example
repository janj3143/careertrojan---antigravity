# =============================================================================
# CareerTrojan Email Service — Environment Variables
# =============================================================================
# Copy to .env and fill in your API keys

# ── Service Configuration ────────────────────────────────────────────────────
EMAIL_SERVICE_PORT=3050
NODE_ENV=production
EMAIL_SERVICE_BASE_URL=http://localhost:8650
USER_PORTAL_URL=http://localhost:8602

# ── Service Authentication ───────────────────────────────────────────────────
# Header name for API key authentication
EMAIL_SERVICE_AUTH_HEADER=X-CareerTrojan-Token
# API key value (required for production)
EMAIL_SERVICE_API_KEY=

# ── Klaviyo (Marketing/Campaigns) ────────────────────────────────────────────
# Get from: https://www.klaviyo.com/account#api-keys-tab
KLAVIYO_API_KEY=

# ── SendGrid (Transactional Email) ───────────────────────────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@careertrojan.com
SENDGRID_FROM_NAME=CareerTrojan
SENDGRID_WEBHOOK_KEY=

# ── Zendesk (Support Tickets) ────────────────────────────────────────────────
# Get from: Admin > Channels > API
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=your-email@company.com
ZENDESK_API_TOKEN=

# ── Token Response System ────────────────────────────────────────────────────
# Secret for signing email response tokens (generate a strong random string)
EMAIL_TOKEN_SECRET=change-me-to-a-secure-random-string-in-production
EMAIL_TOKEN_EXPIRY=7d
